# ==========================================
# Mini LMS - Environment Configuration
# ==========================================
# Copy this file to `.env` or `.env.local` and fill in your values!

# 1. PostgreSQL Database Connection URL (Supabase)
# -----------------------------------------------------------------------------------------
# How to get this in Supabase:
# 1. Go to your Supabase Dashboard -> Select your Project
# 2. Click "Project Settings" (gear icon on the bottom left) -> "Database"
# 3. Scroll down to "Connection string" -> Select the "URI" tab
# 4. Copy the URL and replace [YOUR-PASSWORD] with your actual Supabase database password!
#
# Format: postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Or direct: postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:your_supabase_password_here@db.your_project_ref.supabase.co:5432/postgres"

# 2. NextAuth.js (Auth.js) Configuration
# -----------------------------------------------------------------------------------------
# AUTH_SECRET is required to securely encrypt JWT sessions and cookies.
# You can generate a strong random secret by running: openssl rand -base64 32
# or: npx auth secret
AUTH_SECRET="replace-this-with-a-random-32-character-secret-string"

# Base URL of your application (use http://localhost:3000 for local development)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# 3. Google Gemini AI (AI Studio)
# -----------------------------------------------------------------------------------------
# Used for AI-powered question generation from teacher reference text.
# How to get your API key:
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API Key" -> select your Google Cloud project (or create one)
# 3. Copy the generated key and paste it below
#
# Recommended model: gemini-2.0-flash (fast, cheap, great for structured output)
# Other options: gemini-1.5-pro, gemini-1.5-flash
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_API_URL="https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent"
