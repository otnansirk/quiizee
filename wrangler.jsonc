{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "quiizee",
  "compatibility_date": "2026-07-09",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "quiizee"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "2d07aaca2af846d7a43481dd29315b0e",
      "localConnectionString": "postgresql://postgres.edunmxvcycpogjzzwvgt:4UlfXpZTfocFzAIg@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
    }
  ],
  "vars": {
    "AUTH_URL": "https://quiizee.krisnantobiyuh.workers.dev",
    "NEXTAUTH_URL": "https://quiizee.krisnantobiyuh.workers.dev",
    "GEMINI_API_URL": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent"
  }
}
